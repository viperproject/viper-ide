{
    "compilerOptions": {
        "module": "es2022",
        "moduleResolution": "bundler",
        "target": "es2022",
        "lib": [
            "es2022"
        ],
        "outDir": "./dist",
        "rootDir": "src",
        "sourceMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ]
}
