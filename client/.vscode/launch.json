// A launch configuration that compiles the extension and then opens it inside a new window
{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceRoot}",
                "--disable-extensions"
            ],
            "sourceMaps": true,
            "outFiles": ["${workspaceRoot}/dist/**/*.js"],
            "preLaunchTask": {
                "type": "npm",
                "script": "compile"
            }
        },
        {
            "name": "Debug Extension + ViperServer",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceRoot}",
                "--disable-extensions"
            ],
            "env": {
                "VIPER_SERVER_DEBUG_PORT": "5005"
            },
            "sourceMaps": true,
            "outFiles": ["${workspaceRoot}/dist/**/*.js"],
            "preLaunchTask": {
                "type": "npm",
                "script": "compile"
            }
        },
        {
            "name": "Test",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceRoot}",
                "--extensionTestsPath=${workspaceRoot}/dist/test/index.js"
            ],
            "sourceMaps": true,
            "outFiles": ["${workspaceRoot}/dist/test/**/*.js"],
            "preLaunchTask": {
                "type": "npm",
                "script": "pre-test"
            }
        }
    ]
}
